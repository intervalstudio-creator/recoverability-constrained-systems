    {"source": "Transport", "target": "Ward Staff", "kind": "resource", "criticality": 0.85, "fallback_exists": false},
    {"source": "Ward Staff", "target": "Escalation Line", "kind": "authority", "criticality": 0.90, "fallback_exists": false}
