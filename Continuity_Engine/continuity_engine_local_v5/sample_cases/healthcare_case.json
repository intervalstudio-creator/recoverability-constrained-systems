      "required_entities": ["Ward Staff", "Escalation Line"],
      "required_resources": ["Transport"],
      "degraded_mode_valid": false
    },
    {
      "name": "Local fallback review",
      "executable": true,
      "bounded_minutes": 15,
      "required_entities": ["Ward Staff"],
      "required_resources": [],
      "degraded_mode_valid": true
    }
  ],
  "pressure": 0.75,
  "resonance": 0.35,
  "future_state_preserved": false,
  "signal_sources": [
