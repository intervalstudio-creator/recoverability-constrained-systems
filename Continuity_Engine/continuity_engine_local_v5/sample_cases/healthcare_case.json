    {"name": "response", "current_minutes": 70, "max_minutes": 45},
    {"name": "enforcement", "current_minutes": 30, "max_minutes": 25},
    {"name": "restoration", "current_minutes": 25, "max_minutes": 35},
    {"name": "verification", "current_minutes": 15, "max_minutes": 20}
