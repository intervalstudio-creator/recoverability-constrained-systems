    {"name": "Transport", "type": "resource", "availability": 0.4, "reachable": false, "verifiable": true},
    {"name": "Ward Staff", "type": "team", "availability": 0.5, "reachable": true, "verifiable": true},
    {"name": "Escalation Line", "type": "interface", "availability": 0.3, "reachable": false, "verifiable": true}
  ],
  "dependencies": [
